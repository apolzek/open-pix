# =============================================================================
# Pix Homologation Environment Configuration
# Copy this file to .env and fill in your PSP-specific values
# =============================================================================

# --- PSP Identity ---
PSP_ISPB=12345678                    # Your 8-digit ISPB number
PSP_NAME="My PSP"                    # PSP display name
PSP_PARTICIPANT_TYPE=DIRETO          # DIRETO or INDIRETO

# --- ICOM Connection (SPI) ---
ICOM_BASE_URL=https://icom-h.pi.rsfn.net.br:16522
ICOM_POLL_PATH=/api/v1/in/${PSP_ISPB}/msgs
ICOM_SEND_PATH=/api/v1/out/${PSP_ISPB}/msgs

# --- mTLS Certificates ---
MTLS_CERT_PATH=./certs/client.pem    # Client certificate (PEM)
MTLS_KEY_PATH=./certs/client-key.pem # Client private key (PEM)
MTLS_CA_PATH=./certs/ca-chain.pem    # CA chain (RSFN root + intermediaries)
MTLS_PASSPHRASE=                     # Private key passphrase (if encrypted)

# --- DICT API ---
DICT_BASE_URL=https://dict-h.pi.rsfn.net.br
DICT_API_VERSION=v2

# --- Bacen Test Environment ---
BACEN_SPI_ISPB=99999004              # Bacen virtual participant (SPI)
BACEN_DICT_ISPB=99999060             # Bacen virtual participant (DICT)

# --- Partner PSP (for bilateral tests) ---
PARTNER_ISPB=                        # Partner PSP ISPB
PARTNER_NAME=                        # Partner PSP name

# --- PI Account ---
PI_ACCOUNT_BRANCH=0001               # Branch at Bacen
PI_ACCOUNT_NUMBER=                   # PI account number

# --- HTTP Client Tuning ---
HTTP_MAX_SOCKETS=50                  # Max concurrent TCP connections
HTTP_KEEPALIVE=true                  # TCP keepAlive
HTTP_TIMEOUT_MS=30000                # Request timeout
HTTP_POLL_CONNECTIONS=6              # Max ICOM polling connections

# --- Load Test Parameters ---
SPI_CAPACITY_RATE=2000               # Transactions per minute
SPI_CAPACITY_DURATION=10m            # Test duration
DICT_CAPACITY_LOOKUPS=1000           # Minimum key lookups

# --- Logging ---
LOG_LEVEL=info                       # debug, info, warn, error
LOG_FORMAT=json                      # json or text
